# This jq filter transforms input from the 360Giving Datastore extract in the source_data into the shared model for a funding opportunity
#TODO It doesn't do any enhancement e.g. adding classifications, but it does attempt to split the organisation identifier into a proper identifier object
# The .uri field is consciously set as a grantnav url rather than mapping it from the source data, to achieve consistency and to support interfaces linking out to grantnav to see information about the grant there.

{id: .grant_id, type: "grant", date: .data.awardDate, value: {amount: .data.amountAwarded, currency: .data.currency}, activity: {title: .data.title, description: .data.description, location: (.additional_data.locationLookup | map(select(.source == "beneficiaryLocation")))[0]}, programme: {id: .data.grantProgramme[0].code, title: .data.grantProgramme[0].title, description: .data.grantProgramme[0].description, uri: .data.grantProgramme[0].url}, funder: {id: .data.fundingOrganization[0].id, name: .data.fundingOrganization[0].name, identifiers: [(.data.fundingOrganization[0].charityNumber | select(. != null) | {identifier: ., scheme: "GB-CHC"}),(.data.fundingOrganization[0].companyNumber | select(. != null) | {identifier: ., scheme: "GB-COH"})], classifications: [{value: .additional_data.TSGFundingOrgType, scheme: "TSG-FUNDING-ORG-TYPE"}]}, recipient: {id: .data.recipientOrganization[0].id, name: .data.recipientOrganization[0].name, location: (.additional_data.locationLookup | map(select(.source == "recipientOrganizationLocation")))[0], identifiers: [(.data.recipientOrganization[0].charityNumber | select(. != null) | {identifier: ., scheme: "GB-CHC"}),(.data.recipientOrganization[0].companyNumber | select(. != null) | {identifier: ., scheme: "GB-COH"})]}, uri: "https://grantnav.threesixtygiving.org/grant/\(.data.id)"}
