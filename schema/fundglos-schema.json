        "currency"
      ]
    },
    "Activity": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "title": "Title",
          "description": "The title of the activity, likely taken from the title of the grant or procurement"
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "The description of the activity, likely taken from the description of the grant or procurement"
        },
        "classifications": {
          "type": "array",
          "title": "Classifications",
          "description": "A list of classifications used to describe this activity",
          "items": {
            "$ref": "#/$defs/Classification"
          }
        },
        "location": {
          "$ref": "#/$defs/Location"
        }
      }
    }
  },
  "properties": {
    "id": {
      "title": "Identifier",
      "type": "string",
      "description": "Unique identifier for this funding opportunity. For data converted from 360Giving, use the .id field. For data converted from OCDS, use the .ocid field.",
      "example": "fundglos-0001"
    },
    "type": {
      "title": "Funding Opportunity Type",
      "type": "string",
      "description": "What type of funding this is, i.e. a grant or a procurement suitable for vcses",
      "enum": [
        "grant",
        "procurement"
      ],
      "example": "grant"
    },
    "date": {
      "title": "Date",
      "type": "string",
      "description": "The date of the funding award. In the case of grants, this is the date awarded. In the case of procurements, this is the date of the award",
      "oneOf": [
        {
          "format": "date"
        },
        {
          "format": "date-time"
        }
      ]
    },
    "uri": {
      "title": "URI",
      "type": "string",
      "format": "uri",
      "description": "A URI which points to more information about this opportunity"
    },
    "programme": {
      "$ref": "#/$defs/Programme"
    },
    "activity": {
      "$ref": "#/$defs/Activity"
    }
  }
}
